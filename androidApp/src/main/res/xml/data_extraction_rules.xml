<?xml version="1.0" encoding="utf-8"?>
<!--
   Sample data extraction rules file; uncomment and update as needed.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude all database files from cloud backup — encryption keys are device-specific. -->
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Exclude all database and preferences from device-to-device transfer. -->
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
